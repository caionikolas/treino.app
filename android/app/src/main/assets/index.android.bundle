__d(function(g,r,i,a,m,e,d){Object.defineProperty(e,"__esModule",{value:!0}),e.DEFAULT_EXERCISES=void 0;var o=e.DEFAULT_EXERCISES=[{id:'ex-chest-01',name:'Supino Reto com Barra',muscleGroup:'chest',category:'strength',mediaFilename:'barbell_bench_press.mp4',instructions:'Deite-se no banco, pegue a barra com pegada pouco mais aberta que os ombros. Des\xe7a controlando at\xe9 tocar levemente o peito. Empurre de volta estendendo os bra\xe7os sem travar os cotovelos.',createdAt:0},{id:'ex-chest-02',name:'Supino Reto com Halteres',muscleGroup:'chest',category:'strength',mediaFilename:'dumbbell_bench_press.mp4',instructions:'Deitado no banco, segure os halteres ao lado do peito com palmas para frente. Empurre para cima at\xe9 quase encostar os halteres. Des\xe7a controladamente.',createdAt:0},{id:'ex-chest-03',name:'Supino Inclinado com Halteres',muscleGroup:'chest',category:'strength',mediaFilename:'dumbbell_incline_bench_press.mp4',instructions:'Banco inclinado 30-45\xb0. Halteres ao lado do peito superior. Empurre para cima e des\xe7a com controle.',createdAt:0},{id:'ex-chest-04',name:'Crucifixo com Halteres',muscleGroup:'chest',category:'strength',mediaFilename:'dumbbell_chest_fly.mp4',instructions:'Deitado no banco, bra\xe7os estendidos com leve flex\xe3o no cotovelo. Abra em arco at\xe9 sentir alongamento no peito. Retorne na mesma trajet\xf3ria.',createdAt:0},{id:'ex-chest-05',name:'Crucifixo Inclinado com Halteres',muscleGroup:'chest',category:'strength',mediaFilename:'dumbbell_incline_chest_flys.mp4',instructions:'Banco inclinado. Bra\xe7os semi-flexionados, abra em arco amplo e retorne contraindo o peito.',createdAt:0},{id:'ex-chest-06',name:'Flex\xe3o de Bra\xe7o',muscleGroup:'chest',category:'calisthenics',mediaFilename:'pushup.mp4',instructions:'M\xe3os pouco mais abertas que os ombros, corpo alinhado. Des\xe7a at\xe9 o peito quase tocar o ch\xe3o. Empurre de volta mantendo o core ativo.',createdAt:0},{id:'ex-chest-07',name:'Flex\xe3o Diamante',muscleGroup:'chest',category:'calisthenics',mediaFilename:'diamond_pushup.mp4',instructions:'M\xe3os juntas formando um tri\xe2ngulo sob o peito. Des\xe7a e suba mantendo cotovelos pr\xf3ximos ao corpo.',createdAt:0},{id:'ex-back-01',name:'Remada Curvada com Barra',muscleGroup:'back',category:'strength',mediaFilename:'barbell_bent_over_row.mp4',instructions:'Tronco inclinado \xe0 frente 45\xb0, coluna neutra. Puxe a barra em dire\xe7\xe3o ao abd\xf4men aproximando as esc\xe1pulas. Des\xe7a controlado.',createdAt:0},{id:'ex-back-02',name:'Remada Unilateral com Halter',muscleGroup:'back',category:'strength',mediaFilename:'dumbbell_kneeling_single_arm_row.mp4',instructions:'Apoiado no banco com um joelho e uma m\xe3o. Puxe o halter em dire\xe7\xe3o \xe0 cintura contraindo a esc\xe1pula. Estenda o bra\xe7o completamente na descida.',createdAt:0},{id:'ex-back-03',name:'Remada Inclinada no Banco',muscleGroup:'back',category:'strength',mediaFilename:'dumbbell_laying_incline_row.mp4',instructions:'Deitado de bru\xe7os em banco inclinado. Puxe os halteres at\xe9 a linha do tronco, contraindo esc\xe1pulas. Des\xe7a controlado.',createdAt:0},{id:'ex-back-04',name:'Barra Fixa (Pull-up)',muscleGroup:'back',category:'calisthenics',mediaFilename:'pullup.mp4',instructions:'Pegada pronada, m\xe3os pouco mais abertas que os ombros. Puxe at\xe9 o queixo passar a barra. Des\xe7a com controle at\xe9 bra\xe7os estendidos.',createdAt:0},{id:'ex-back-05',name:'Barra Supinada (Chin-up)',muscleGroup:'back',category:'calisthenics',mediaFilename:'chinup.mp4',instructions:'Pegada supinada na largura dos ombros. Puxe trazendo o peito em dire\xe7\xe3o \xe0 barra. Des\xe7a controlado.',createdAt:0},{id:'ex-back-06',name:'Remada Australiana',muscleGroup:'back',category:'calisthenics',mediaFilename:'australian_pullup.mp4',instructions:'Corpo sob barra baixa, calcanhares no ch\xe3o, corpo reto. Puxe o peito at\xe9 a barra e retorne estendendo os bra\xe7os.',createdAt:0},{id:'ex-shoulder-01',name:'Desenvolvimento Militar com Halteres',muscleGroup:'shoulder',category:'strength',mediaFilename:'dumbbell_shoulder_press.mp4',instructions:'Sentado ou em p\xe9, halteres ao n\xedvel dos ombros. Empurre para cima at\xe9 quase estender os bra\xe7os. Des\xe7a controlado.',createdAt:0},{id:'ex-shoulder-02',name:'Eleva\xe7\xe3o Lateral',muscleGroup:'shoulder',category:'strength',mediaFilename:'dumbbell_lateral_raise.mp4',instructions:'Em p\xe9, halteres ao lado do corpo, cotovelos levemente flexionados. Eleve os bra\xe7os at\xe9 a linha dos ombros. Des\xe7a controlado.',createdAt:0},{id:'ex-shoulder-03',name:'Eleva\xe7\xe3o Frontal',muscleGroup:'shoulder',category:'strength',mediaFilename:'dumbbell_front_raise.mp4',instructions:'Em p\xe9, halteres \xe0 frente das coxas. Eleve um bra\xe7o por vez at\xe9 a altura dos ombros, mantendo leve flex\xe3o no cotovelo. Des\xe7a controlado.',createdAt:0},{id:'ex-shoulder-04',name:'Desenvolvimento Arnold',muscleGroup:'shoulder',category:'strength',mediaFilename:'arnold_press.mp4',instructions:'Comece com halteres \xe0 frente, palmas voltadas para voc\xea. Gire os punhos enquanto empurra para cima. Des\xe7a invertendo o movimento.',createdAt:0},{id:'ex-shoulder-05',name:'Pike Push-up',muscleGroup:'shoulder',category:'calisthenics',mediaFilename:'pike_pushup.mp4',instructions:'Posi\xe7\xe3o de V invertido com quadril elevado. Des\xe7a o topo da cabe\xe7a em dire\xe7\xe3o ao ch\xe3o flexionando os cotovelos. Empurre de volta.',createdAt:0},{id:'ex-biceps-01',name:'Rosca Direta com Halteres',muscleGroup:'biceps',category:'strength',mediaFilename:'dumbbell_curl.mp4',instructions:'Em p\xe9, halteres ao lado do corpo com palmas para frente. Flexione os cotovelos trazendo os halteres em dire\xe7\xe3o aos ombros. Des\xe7a controlado.',createdAt:0},{id:'ex-biceps-02',name:'Rosca Alternada',muscleGroup:'biceps',category:'strength',mediaFilename:'dumbbell_alternating_curl.mp4',instructions:'Alterne as flex\xf5es de bra\xe7o, um de cada vez, com palma supinada. Mantenha o cotovelo fixo ao lado do corpo.',createdAt:0},{id:'ex-biceps-03',name:'Rosca Martelo',muscleGroup:'biceps',category:'strength',mediaFilename:'dumbbell_hammer_curl.mp4',instructions:'Halteres com pegada neutra (palmas voltadas uma para outra). Flexione mantendo os punhos neutros. Des\xe7a controlado.',createdAt:0},{id:'ex-biceps-04',name:'Rosca Scott Unilateral',muscleGroup:'biceps',category:'strength',mediaFilename:'dumbbell_single_arm_preacher_curl.mp4',instructions:'Bra\xe7o apoiado no banco Scott, halter em pegada supinada. Flexione sem mover o cotovelo. Des\xe7a at\xe9 quase estender o bra\xe7o.',createdAt:0},{id:'ex-biceps-05',name:'Rosca Concentrada',muscleGroup:'biceps',category:'strength',mediaFilename:'dumbbell_concentration_curl.mp4',instructions:'Sentado, cotovelo apoiado na parte interna da coxa. Flexione o bra\xe7o em dire\xe7\xe3o ao ombro mantendo o cotovelo fixo.',createdAt:0},{id:'ex-triceps-01',name:'Tr\xedceps Testa com Halteres',muscleGroup:'triceps',category:'strength',mediaFilename:'dumbbell_skullcrusher.mp4',instructions:'Deitado no banco, halteres acima do peito com bra\xe7os estendidos. Flexione s\xf3 os cotovelos levando os halteres pr\xf3ximos \xe0 testa. Estenda de volta.',createdAt:0},{id:'ex-triceps-02',name:'Extens\xe3o de Tr\xedceps Acima da Cabe\xe7a',muscleGroup:'triceps',category:'strength',mediaFilename:'dumbbell_overhead_tricep_extension.mp4',instructions:'Sentado ou em p\xe9, segure um halter com as duas m\xe3os acima da cabe\xe7a. Flexione os cotovelos descendo o halter atr\xe1s da cabe\xe7a. Estenda de volta.',createdAt:0},{id:'ex-triceps-03',name:'Tr\xedceps Coice',muscleGroup:'triceps',category:'strength',mediaFilename:'dumbbell_tricep_kickback.mp4',instructions:'Tronco inclinado, cotovelo flexionado pr\xf3ximo ao tronco. Estenda o bra\xe7o para tr\xe1s at\xe9 a linha do ombro. Retorne controlado.',createdAt:0},{id:'ex-triceps-04',name:'Mergulho entre Bancos',muscleGroup:'triceps',category:'calisthenics',mediaFilename:'bench_dips.mp4',instructions:'M\xe3os em um banco atr\xe1s de voc\xea, p\xe9s no ch\xe3o ou em outro banco. Des\xe7a flexionando os cotovelos. Empurre de volta.',createdAt:0},{id:'ex-triceps-05',name:'Flex\xe3o Fechada',muscleGroup:'triceps',category:'calisthenics',mediaFilename:'close_grip_pushup.mp4',instructions:'Flex\xe3o com m\xe3os pr\xf3ximas entre si, cotovelos colados ao corpo na descida. Empurre de volta contraindo o tr\xedceps.',createdAt:0},{id:'ex-legs-01',name:'Agachamento Livre com Barra',muscleGroup:'legs',category:'strength',mediaFilename:'barbell_squat.mp4',instructions:'Barra apoiada nos trap\xe9zios, p\xe9s na largura dos ombros. Des\xe7a flexionando quadril e joelhos at\xe9 coxas paralelas ao ch\xe3o. Suba empurrando o ch\xe3o.',createdAt:0},{id:'ex-legs-02',name:'Agachamento Goblet',muscleGroup:'legs',category:'strength',mediaFilename:'dumbbell_goblet_squat.mp4',instructions:'Segure um halter verticalmente contra o peito. Agache mantendo o tronco ereto. Suba empurrando pelos calcanhares.',createdAt:0},{id:'ex-legs-03',name:'Afundo com Halteres',muscleGroup:'legs',category:'strength',mediaFilename:'dumbbell_lunge.mp4',instructions:'Halteres ao lado do corpo. D\xea um passo \xe0 frente e des\xe7a flexionando os dois joelhos em 90\xb0. Empurre de volta \xe0 posi\xe7\xe3o inicial.',createdAt:0},{id:'ex-legs-04',name:'Stiff com Halteres',muscleGroup:'legs',category:'strength',mediaFilename:'dumbbell_stiff_deadlift.mp4',instructions:'Halteres \xe0 frente das coxas, joelhos levemente flexionados. Des\xe7a inclinando o quadril para tr\xe1s, costas neutras, at\xe9 sentir posteriores. Suba contraindo gl\xfateos.',createdAt:0},{id:'ex-legs-05',name:'Eleva\xe7\xe3o de Panturrilha',muscleGroup:'legs',category:'strength',mediaFilename:'dumbbell_calf_raise.mp4',instructions:'Em p\xe9 com halteres, suba na ponta dos p\xe9s contraindo panturrilhas. Des\xe7a controlado at\xe9 a posi\xe7\xe3o inicial.',createdAt:0},{id:'ex-legs-06',name:'Agachamento B\xfalgaro',muscleGroup:'legs',category:'strength',mediaFilename:'dumbbell_bulgarian_split_squat.mp4',instructions:'P\xe9 de tr\xe1s apoiado em banco, halteres ao lado. Des\xe7a flexionando o joelho da frente. Suba empurrando pela perna da frente.',createdAt:0},{id:'ex-legs-07',name:'Agachamento Pistol',muscleGroup:'legs',category:'calisthenics',mediaFilename:'pistol_squat.mp4',instructions:'Agachamento em uma perna s\xf3, outra perna estendida \xe0 frente. Des\xe7a controlado e suba com for\xe7a na perna de apoio.',createdAt:0},{id:'ex-core-01',name:'Prancha Abdominal',muscleGroup:'core',category:'calisthenics',mediaFilename:'plank.mp4',instructions:'Apoio nos antebra\xe7os e pontas dos p\xe9s, corpo alinhado em linha reta. Contraia core e gl\xfateos. Mantenha pelo tempo determinado.',createdAt:0},{id:'ex-core-02',name:'Prancha Lateral',muscleGroup:'core',category:'calisthenics',mediaFilename:'side_plank.mp4',instructions:'Apoio em um antebra\xe7o e lateral do p\xe9, corpo alinhado. Quadril elevado. Mantenha contraindo obl\xedquos.',createdAt:0},{id:'ex-core-03',name:'Abdominal Crunch',muscleGroup:'core',category:'calisthenics',mediaFilename:'crunch.mp4',instructions:'Deitado de costas, joelhos flexionados. Eleve o tronco at\xe9 as esc\xe1pulas sa\xedrem do ch\xe3o contraindo o abd\xf4men. Des\xe7a controlado.',createdAt:0},{id:'ex-core-04',name:'Eleva\xe7\xe3o de Pernas',muscleGroup:'core',category:'calisthenics',mediaFilename:'leg_raise.mp4',instructions:'Deitado de costas, pernas estendidas. Eleve as pernas at\xe9 90\xb0 mantendo a lombar no ch\xe3o. Des\xe7a controlado sem tocar o ch\xe3o.',createdAt:0},{id:'ex-core-05',name:'Russian Twist',muscleGroup:'core',category:'calisthenics',mediaFilename:'russian_twist.mp4',instructions:'Sentado com tronco inclinado e p\xe9s elevados. Gire o tronco de um lado para o outro tocando as m\xe3os (ou peso) no ch\xe3o.',createdAt:0},{id:'ex-fullbody-01',name:'Burpee',muscleGroup:'full_body',category:'calisthenics',mediaFilename:'burpee.mp4',instructions:'Des\xe7a ao ch\xe3o, fa\xe7a uma flex\xe3o, recolha as pernas, salte para cima. Repita fluidamente.',createdAt:0},{id:'ex-fullbody-02',name:'Mountain Climber',muscleGroup:'full_body',category:'calisthenics',mediaFilename:'mountain_climber.mp4',instructions:'Em posi\xe7\xe3o de prancha alta, traga os joelhos alternadamente em dire\xe7\xe3o ao peito em ritmo acelerado.',createdAt:0},{id:'ex-fullbody-03',name:'Bear Crawl',muscleGroup:'full_body',category:'calisthenics',mediaFilename:'bear_crawl.mp4',instructions:'Apoio nas m\xe3os e p\xe9s com joelhos pr\xf3ximos ao ch\xe3o sem tocar. Avance com bra\xe7o e perna opostos simultaneamente.',createdAt:0},{id:'ex-fullbody-04',name:'Thruster com Halteres',muscleGroup:'full_body',category:'strength',mediaFilename:'dumbbell_thruster.mp4',instructions:'Halteres na altura dos ombros. Agache e, ao subir, empurre os halteres acima da cabe\xe7a em um movimento \xfanico.',createdAt:0}],t=Date.now();o.forEach(function(o){o.createdAt=t})},491,[]);
